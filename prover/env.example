# Phase 1 Operator 환경변수 (Sepolia → Metadium testnet)
# 실제 값은 prover/config/metadium-testnet.env 에 기입 (gitignore됨)

# ─── Destination: Metadium testnet ───
DEST_RPC_URL=https://api.metadium.com/dev
DEST_CHAIN_ID=12
CONTRACT_ADDRESS=0xEaF9Ceb5da50C7396fa6111aC498ff3a34Be94D7
PRIVATE_KEY=0x...                        # operator tx 서명용 (= DEPLOYER EOA)

# ─── Source: Ethereum Sepolia ───
SOURCE_CHAIN_ID=11155111
SOURCE_CONSENSUS_RPC=https://ethereum-sepolia-beacon-api.publicnode.com
SOURCE_EXECUTION_RPC=https://ethereum-sepolia-rpc.publicnode.com

# ─── SP1 LocalProver (150번 H100 GPU) ───
SP1_PROVER=cuda                          # mock | local (CPU) | cuda (GPU) | network
CUDA_VISIBLE_DEVICES=1                   # GPU 1번 사용 (GPU 0은 Ollama 점유)

# ─── Operator 동작 ───
LOOP_DELAY_MINS=30                       # 기본 5. PoC에선 30 권장
