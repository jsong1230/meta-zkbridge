# Phase 1 Operator 환경변수 (Sepolia → Metadium testnet)
# 실제 값은 prover/config/metadium-testnet.env 에 기입 (gitignore됨)

# ─── Destination: Metadium testnet ───
DEST_RPC_URL=https://api.metadium.com/dev
DEST_CHAIN_ID=12
CONTRACT_ADDRESS=0x...                   # SP1Helios.sol 배포 후 채움
PRIVATE_KEY=0x...                        # operator tx 서명용 (= DEPLOYER EOA도 겸용 가능)

# ─── Source: Ethereum Sepolia ───
SOURCE_CHAIN_ID=11155111
SOURCE_CONSENSUS_RPC=https://www.lightclientdata.org  # sp1-helios 기본값, Sepolia는 별도 필요
SOURCE_EXECUTION_RPC=https://ethereum-sepolia-rpc.publicnode.com

# ─── SP1 Prover Network ───
SP1_PROVER=network                       # mock | local | network
NETWORK_RPC_URL=https://rpc.succinct.xyz/
NETWORK_PRIVATE_KEY=0x...                # Succinct dev wallet (배포 키와 분리!)

# ─── Operator 동작 ───
LOOP_DELAY_MINS=30                       # 기본 5. PoC 비용 절감 위해 30~60 권장
